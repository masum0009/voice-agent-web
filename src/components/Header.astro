---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Platform</HeaderLink>
			<HeaderLink href="/docs/introduction">Docs</HeaderLink>
			<HeaderLink href="/pricing">Pricing</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://github.com/your-org/open-bolna" target="_blank" class="github-link">
				<span class="sr-only">Go to OpenBolna's GitHub repo</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24">
					<path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path>
				</svg>
				<span>Star on GitHub</span>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 2em;
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid #eaeaea;
		position: sticky;
		top: 0;
		z-index: 100;
	}
	h2 {
		margin: 0;
		font-size: 1.25em;
		font-weight: 700;
		letter-spacing: -0.5px;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #111;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 4rem;
		max-width: 1200px;
		margin: 0 auto;
	}
	.internal-links {
		display: flex;
		gap: 2rem;
	}
	nav a {
		padding: 0;
		color: #444;
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		transition: color 0.2s;
	}
	nav a:hover {
		color: #000;
	}
	nav a.active {
		font-weight: 600;
		color: #000;
	}
	.social-links,
	.social-links a {
		display: flex;
		align-items: center;
	}
	.github-link {
		background: #111;
		color: #fff !important;
		padding: 0.5rem 1rem !important;
		border-radius: 6px;
		gap: 0.5rem;
		font-weight: 500;
		font-size: 0.9rem;
		transition: transform 0.2s;
	}
	.github-link:hover {
		transform: translateY(-1px);
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
		.internal-links {
			display: none;
		}
	}
</style>
