---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Pricing - ${SITE_TITLE}`} description="View our flexible pricing plans for OpenVoice." />
		<style>
			main {
				width: 100%;
				max-width: 1200px;
				margin: 0 auto;
				padding: 4rem 2rem;
				font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
			}
			.pricing-header {
				text-align: center;
				margin-bottom: 4rem;
			}
			.pricing-header h1 {
				font-size: 3rem;
				font-weight: 800;
				margin-bottom: 1rem;
				color: #111;
			}
			.pricing-header p {
				font-size: 1.25rem;
				color: #555;
				max-width: 600px;
				margin: 0 auto;
			}
			.pricing-grid {
				display: grid;
				grid-template-columns: repeat(1, 1fr);
				gap: 2rem;
				margin-bottom: 4rem;
			}
			@media (min-width: 900px) {
				.pricing-grid {
					grid-template-columns: repeat(3, 1fr);
				}
			}
			.pricing-card {
				background: #fff;
				border: 1px solid #eaeaea;
				border-radius: 16px;
				padding: 2rem 1.5rem;
				text-align: center;
				transition: transform 0.2s, box-shadow 0.2s;
				display: flex;
				flex-direction: column;
			}
			.pricing-card:hover {
				transform: translateY(-8px);
				box-shadow: 0 20px 40px rgba(0,0,0,0.08);
			}
			.pricing-card.popular {
				border: 2px solid #000;
				position: relative;
			}
			.popular-badge {
				position: absolute;
				top: -12px;
				left: 50%;
				transform: translateX(-50%);
				background: #000;
				color: #fff;
				padding: 0.25rem 0.75rem;
				border-radius: 20px;
				font-size: 0.75rem;
				font-weight: 600;
				letter-spacing: 0.5px;
				text-transform: uppercase;
			}
			.plan-name {
				font-size: 1.25rem;
				font-weight: 700;
				margin-bottom: 0.75rem;
				color: #111;
			}
			.plan-price {
				font-size: 2.25rem;
				font-weight: 800;
				margin-bottom: 1.5rem;
				color: #000;
			}
			.plan-price span {
				font-size: 0.9rem;
				color: #666;
				font-weight: 500;
			}
			.features-list {
				list-style: none;
				padding: 0;
				margin: 0 0 1.5rem 0;
				text-align: left;
				flex-grow: 1;
			}
			.features-list li {
				padding: 0.5rem 0;
				color: #444;
				font-size: 0.9rem;
				border-bottom: 1px solid #f1f1f1;
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.features-list li::before {
				content: "✓";
				color: #000;
				font-weight: bold;
			}
			.btn {
				padding: 0.8rem 1.5rem;
				border-radius: 8px;
				font-size: 0.9rem;
				font-weight: 600;
				text-decoration: none;
				transition: all 0.2s;
				display: inline-block;
				width: 100%;
				box-sizing: border-box;
			}
			.btn-primary {
				background: #000;
				color: #fff;
			}
			.btn-primary:hover {
				background: #222;
			}
			.btn-outline {
				background: transparent;
				color: #000;
				border: 1px solid #000;
			}
			.btn-outline:hover {
				background: #f8f8f8;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="pricing-header">
				<h1>Simple, transparent pricing</h1>
				<p>Whether you're building a side project or running a large enterprise customer service, we have a plan for you.</p>
			</div>

			<div class="pricing-grid">
				<!-- Starter Plan -->
				<div class="pricing-card">
					<h2 class="plan-name">Starter</h2>
					<div class="plan-price">$0<span>/mo</span></div>
					<ul class="features-list">
						<li>Up to 1,000 minutes per month</li>
						<li>Community support</li>
						<li>Access to standard voices</li>
						<li>Self-hosted only</li>
						<li>Single workspace</li>
					</ul>
					<a href="https://github.com/your-org/open-bolna" class="btn btn-outline">Deploy for Free</a>
				</div>

				<!-- Pro Plan -->
				<div class="pricing-card popular">
					<div class="popular-badge">Most Popular</div>
					<h2 class="plan-name">Pro</h2>
					<div class="plan-price">$99<span>/mo</span></div>
					<ul class="features-list">
						<li>Up to 10,000 minutes per month</li>
						<li>Priority email support</li>
						<li>Ultra-realistic premium voices</li>
						<li>Managed cloud hosting</li>
						<li>API access & webhooks</li>
						<li>Unlimited workspaces</li>
					</ul>
					<a href="#" class="btn btn-primary">Start Free Trial</a>
				</div>

				<!-- Enterprise Plan -->
				<div class="pricing-card">
					<h2 class="plan-name">Enterprise</h2>
					<div class="plan-price">Custom</div>
					<ul class="features-list">
						<li>Unlimited minutes</li>
						<li>24/7 dedicated support team</li>
						<li>Custom voice cloning</li>
						<li>On-premise deployment options</li>
						<li>SSO & advanced security</li>
						<li>SLA guarantees</li>
					</ul>
					<a href="#" class="btn btn-outline">Contact Sales</a>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>